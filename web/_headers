# Cloudflare static-assets headers. Read-only static hub, no auth, no forms.

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.xml
  Cache-Control: public, max-age=0, must-revalidate

/*.css
  Cache-Control: public, max-age=0, must-revalidate

# Security headers. CSP: script-src 'self' (only the inline JSON-LD data block,
# which is not executable script); style-src allows inline style="--yr:…" attrs;
# img-src allows the inline SVG favicon via data: URI.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
